#!/bin/bash
# Pre-commit hook: abort if resume.yml is staged without SOPS encryption.

RESUME_FILE="src/_data/resume.yml"

if ! git diff --cached --name-only | grep -q "^${RESUME_FILE}$"; then
  exit 0
fi

# SOPS-encrypted YAML files contain an "sops:" key
if ! git show ":${RESUME_FILE}" | grep -q "^sops:"; then
  echo ""
  echo "ERROR: ${RESUME_FILE} is staged but does not appear to be SOPS-encrypted."
  echo "  This would commit the file in plaintext. Aborting."
  echo "  Encrypt with: sops --encrypt --in-place ${RESUME_FILE}"
  echo ""
  exit 1
fi

exit 0
