# GitHub (https://github.com/settings/tokens)
# Fine-grained token with public repository read access (or classic token with public_repo scope)
GITHUB_TOKEN=

# Cloudflare Turnstile (https://dash.cloudflare.com -> Turnstile)
# For local dev, use Cloudflare's test keys: site=1x00000000000000000000AA secret=1x0000000000000000000000000000000AA
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Resend (https://resend.com)
RESEND_API_KEY=
RESEND_FROM=Contact Form <noreply@yourdomain.com>
RESEND_TO=you@yourdomain.com

# git-crypt (optional — only needed to unlock encrypted resume.yml locally)
# Generate with: git-crypt export-key /tmp/git-crypt-key && base64 /tmp/git-crypt-key
GIT_CRYPT_KEY=

# Resume (Cloudflare Access — Zero Trust → Access → Applications)
# Set to true locally to bypass auth; leave unset in production
CF_ACCESS_BYPASS=
# Team domain: yourteam.cloudflareaccess.com
CF_ACCESS_TEAM_DOMAIN=
# Application Audience tag from the Access application settings
CF_ACCESS_AUD=
